# Environment: DATABASE_URL
# Copy to packages/db/.env for local Prisma CLI (never commit real secrets).

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Capability token pepper/TTL live in apps/web server configuration (CAPABILITY_TOKEN_PEPPER /
# CAPABILITY_TTL_MS). Do not put secrets in this Prisma package env file beyond DATABASE_URL.
