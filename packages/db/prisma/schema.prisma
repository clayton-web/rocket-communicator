generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Recipient contact record for an Owner organization. Not an application account (D049).
model Recipient {
  id                   String   @id @db.VarChar(64)
  organizationId       String   @map("organization_id") @db.VarChar(64)
  displayName          String   @map("display_name") @db.VarChar(256)
  email                String   @db.VarChar(320)
  relationshipLabel    String?  @map("relationship_label") @db.VarChar(64)
  active               Boolean  @default(true)
  reminderPreferences  Json?    @map("reminder_preferences")
  assignmentCategories Json?    @map("assignment_categories")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  assignments  TaskAssignment[]
  capabilities TaskCapability[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("recipients")
}

model Task {
  id                    String        @id @db.VarChar(64)
  organizationId        String        @map("organization_id") @db.VarChar(64)
  status                TaskStatus
  priorActionableStatus TaskStatus?   @map("prior_actionable_status")
  summaryPoints         Json          @map("summary_points")
  sourceReference       Json?         @map("source_reference")
  dueAt                 DateTime?     @map("due_at") @db.Timestamptz(3)
  waitingUntil          DateTime?     @map("waiting_until") @db.Timestamptz(3)
  priority              TaskPriority?
  outcome               Json?
  reminder              Json
  retention             Json
  version               Int           @default(1)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  assignments            TaskAssignment[]
  notes                  TaskNote[]
  capabilities           TaskCapability[]
  suggestionsMerged      TaskSuggestion[] @relation("MergedIntoTask")
  /// Suggestion that created this Task via Owner approve (D080/D082). At most one.
  approvedFromSuggestion TaskSuggestion?  @relation("ApprovedTask")

  @@index([organizationId, status])
  @@index([organizationId, updatedAt])
  @@map("tasks")
}

/// Assignment history for a task. Multiple rows per task over time are allowed.
/// At most one active assignment (`clearedAt` IS NULL) is enforced by a partial unique
/// index in migration SQL (not expressible accurately in Prisma schema metadata).
model TaskAssignment {
  id                       String                    @id @db.VarChar(64)
  organizationId           String                    @map("organization_id") @db.VarChar(64)
  taskId                   String                    @map("task_id") @db.VarChar(64)
  recipientId              String                    @map("recipient_id") @db.VarChar(64)
  intendedRecipientEmail   String                    @map("intended_recipient_email") @db.VarChar(320)
  assignedAt               DateTime                  @map("assigned_at") @db.Timestamptz(3)
  assignedByOwnerId        String                    @map("assigned_by_owner_id") @db.VarChar(64)
  assignmentApprovedAt     DateTime?                 @map("assignment_approved_at") @db.Timestamptz(3)
  allowedCapabilityActions Json                      @map("allowed_capability_actions")
  capabilityStatus         CapabilityStatus?         @map("capability_status")
  deliveryStatus           AssignmentDeliveryStatus? @map("delivery_status")
  activeCapabilityId       String?                   @map("active_capability_id") @db.VarChar(64)
  /// Null while assignment is current; set when returned/cleared. Cleared rows are immutable history.
  clearedAt                DateTime?                 @map("cleared_at") @db.Timestamptz(3)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)

  task         Task             @relation(fields: [taskId], references: [id], onDelete: Restrict)
  recipient    Recipient        @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  capabilities TaskCapability[]

  @@index([taskId])
  @@index([organizationId])
  @@index([recipientId])
  @@map("task_assignments")
}

model TaskNote {
  id             String   @id @db.VarChar(64)
  organizationId String   @map("organization_id") @db.VarChar(64)
  taskId         String   @map("task_id") @db.VarChar(64)
  body           String   @db.VarChar(2000)
  /// ActionAttribution JSON (owner | capability). Must not claim verified Recipient identity.
  attribution    Json
  createdAt      DateTime @map("created_at") @db.Timestamptz(3)

  task Task @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([organizationId, taskId])
  @@index([taskId, createdAt])
  @@map("task_notes")
}

model TaskSuggestion {
  id                         String               @id @db.VarChar(64)
  organizationId             String               @map("organization_id") @db.VarChar(64)
  status                     TaskSuggestionStatus
  summaryPoints              Json                 @map("summary_points")
  sourceReference            Json?                @map("source_reference")
  proposedRecipientId        String?              @map("proposed_recipient_id") @db.VarChar(64)
  proposedDueAt              DateTime?            @map("proposed_due_at") @db.Timestamptz(3)
  proposedPriority           TaskPriority?        @map("proposed_priority")
  voiceOriginated            Boolean              @default(false) @map("voice_originated")
  /// Optional originating task for Recipient work requests (D061).
  originTaskId               String?              @map("origin_task_id") @db.VarChar(64)
  /// Authoritative Gmail-origin link (D081). Null for work-request suggestions. Unique when set.
  sourceCommunicationEventId String?              @unique @map("source_communication_event_id") @db.VarChar(64)
  /// Task created by Owner approve of this suggestion (D080/D082). Unique when set.
  approvedTaskId             String?              @unique @map("approved_task_id") @db.VarChar(64)
  mergedIntoTaskId           String?              @map("merged_into_task_id") @db.VarChar(64)
  retention                  Json
  version                    Int                  @default(1)
  createdAt                  DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  mergedIntoTask           Task?               @relation("MergedIntoTask", fields: [mergedIntoTaskId], references: [id], onDelete: SetNull)
  approvedTask             Task?               @relation("ApprovedTask", fields: [approvedTaskId], references: [id], onDelete: Restrict)
  sourceCommunicationEvent CommunicationEvent? @relation(fields: [sourceCommunicationEventId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([organizationId, originTaskId])
  @@map("task_suggestions")
}

/// Capability authorization record. Stores token HASH only — never raw secrets (D063).
model TaskCapability {
  id                     String           @id @db.VarChar(64)
  organizationId         String           @map("organization_id") @db.VarChar(64)
  taskId                 String           @map("task_id") @db.VarChar(64)
  assignmentId           String           @map("assignment_id") @db.VarChar(64)
  recipientId            String?          @map("recipient_id") @db.VarChar(64)
  intendedRecipientEmail String           @map("intended_recipient_email") @db.VarChar(320)
  scope                  Json
  status                 CapabilityStatus
  /// SHA-256 (or stronger) hex/base64url fingerprint of the raw secret. Unique.
  tokenHash              String           @unique @map("token_hash") @db.VarChar(128)
  issuedAt               DateTime         @map("issued_at") @db.Timestamptz(3)
  /// Explicit persisted expiry (D055).
  expiresAt              DateTime         @map("expires_at") @db.Timestamptz(3)
  revokedAt              DateTime?        @map("revoked_at") @db.Timestamptz(3)
  revocationReason       String?          @map("revocation_reason") @db.VarChar(256)
  /// Optional activity stamp; does not imply CapabilityStatus.used (D056).
  lastUsedAt             DateTime?        @map("last_used_at") @db.Timestamptz(3)
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  task       Task           @relation(fields: [taskId], references: [id], onDelete: Restrict)
  assignment TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Restrict)
  recipient  Recipient?     @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([organizationId, taskId])
  @@index([organizationId, status, expiresAt])
  @@index([assignmentId])
  @@map("task_capabilities")
}

/// A4 audit events (D057). Extended in A5 with system actor (D074) and optional Gmail refs.
model AuditEvent {
  id                     String         @id @db.VarChar(64)
  organizationId         String         @map("organization_id") @db.VarChar(64)
  actorKind              AuditActorKind @map("actor_kind")
  ownerId                String?        @map("owner_id") @db.VarChar(64)
  capabilityId           String?        @map("capability_id") @db.VarChar(64)
  /// System actor identifier when actorKind = system (D074). Never a Gmail token.
  systemId               String?        @map("system_id") @db.VarChar(64)
  assignmentId           String?        @map("assignment_id") @db.VarChar(64)
  taskId                 String?        @map("task_id") @db.VarChar(64)
  suggestionId           String?        @map("suggestion_id") @db.VarChar(64)
  communicationAccountId String?        @map("communication_account_id") @db.VarChar(64)
  communicationEventId   String?        @map("communication_event_id") @db.VarChar(64)
  gmailSyncRunId         String?        @map("gmail_sync_run_id") @db.VarChar(64)
  intendedRecipientEmail String?        @map("intended_recipient_email") @db.VarChar(320)
  action                 String         @db.VarChar(64)
  outcome                AuditOutcome
  resourceVersion        Int?           @map("resource_version")
  taskStatus             String?        @map("task_status") @db.VarChar(32)
  note                   String?        @db.VarChar(2000)
  requestId              String?        @map("request_id") @db.VarChar(64)
  correlationId          String?        @map("correlation_id") @db.VarChar(64)
  /// Human-readable label; must not claim verified Recipient identity (D051/D052).
  attributionLabel       String?        @map("attribution_label") @db.VarChar(256)
  recordedAt             DateTime       @map("recorded_at") @db.Timestamptz(3)

  @@index([organizationId, recordedAt])
  @@index([organizationId, taskId])
  @@index([organizationId, capabilityId])
  @@index([organizationId, communicationAccountId])
  @@index([requestId])
  @@map("audit_events")
}

/// One Gmail mailbox connection per organization (A5). Tokens live in GmailOAuthCredential only.
model CommunicationAccount {
  id                String                     @id @db.VarChar(64)
  organizationId    String                     @map("organization_id") @db.VarChar(64)
  provider          CommunicationProvider
  emailAddress      String                     @map("email_address") @db.VarChar(320)
  externalAccountId String                     @map("external_account_id") @db.VarChar(256)
  status            CommunicationAccountStatus
  historyId         String?                    @map("history_id") @db.VarChar(128)
  historyState      GmailHistoryState          @map("history_state")
  connectedAt       DateTime?                  @map("connected_at") @db.Timestamptz(3)
  disconnectedAt    DateTime?                  @map("disconnected_at") @db.Timestamptz(3)
  lastSyncAt        DateTime?                  @map("last_sync_at") @db.Timestamptz(3)
  lastSuccessAt     DateTime?                  @map("last_success_at") @db.Timestamptz(3)
  lastErrorCode     String?                    @map("last_error_code") @db.VarChar(64)
  lastErrorAt       DateTime?                  @map("last_error_at") @db.Timestamptz(3)
  syncLockUntil     DateTime?                  @map("sync_lock_until") @db.Timestamptz(3)
  /// Opaque lock owner (sync run / request id). Only the owner may release a non-expired lock.
  syncLockOwner     String?                    @map("sync_lock_owner") @db.VarChar(64)
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  credential GmailOAuthCredential?
  events     CommunicationEvent[]
  syncRuns   GmailSyncRun[]

  @@unique([organizationId, provider])
  @@index([organizationId, status])
  @@index([syncLockUntil])
  @@map("communication_accounts")
}

/// Encrypted Gmail OAuth material (D070). Ciphertext only — no encryption implementation in A5.1–A5.2.
model GmailOAuthCredential {
  id                    String    @id @db.VarChar(64)
  accountId             String    @unique @map("account_id") @db.VarChar(64)
  organizationId        String    @map("organization_id") @db.VarChar(64)
  encryptedRefreshToken String    @map("encrypted_refresh_token") @db.Text
  encryptedAccessToken  String?   @map("encrypted_access_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  grantedScopes         String    @map("granted_scopes") @db.VarChar(512)
  tokenType             String?   @map("token_type") @db.VarChar(32)
  encryptionKeyVersion  String    @map("encryption_key_version") @db.VarChar(64)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  account CommunicationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("gmail_oauth_credentials")
}

/// Minimized Gmail communication event (D067–D072, D077). No MIME/HTML archives or attachment bytes.
model CommunicationEvent {
  id                           String                     @id @db.VarChar(64)
  organizationId               String                     @map("organization_id") @db.VarChar(64)
  accountId                    String                     @map("account_id") @db.VarChar(64)
  sourceType                   String                     @map("source_type") @db.VarChar(32)
  providerMessageId            String                     @map("provider_message_id") @db.VarChar(256)
  providerThreadId             String                     @map("provider_thread_id") @db.VarChar(256)
  dedupeKey                    String                     @map("dedupe_key") @db.VarChar(128)
  internalDate                 DateTime                   @map("internal_date") @db.Timestamptz(3)
  receivedAt                   DateTime                   @map("received_at") @db.Timestamptz(3)
  fromAddress                  String                     @map("from_address") @db.VarChar(320)
  toAddresses                  Json                       @map("to_addresses")
  subject                      String?                    @db.VarChar(256)
  snippet                      String?                    @db.VarChar(512)
  labelIds                     Json                       @map("label_ids")
  hasAttachments               Boolean                    @default(false) @map("has_attachments")
  attachmentMetadata           Json                       @map("attachment_metadata")
  status                       CommunicationEventStatus
  ingestRunId                  String?                    @map("ingest_run_id") @db.VarChar(64)
  purgeAt                      DateTime?                  @map("purge_at") @db.Timestamptz(3)
  /// D081 suggestion-processing state (A6). A5 ingest leaves events as unprocessed.
  suggestionProcessingStatus   SuggestionProcessingStatus @default(unprocessed) @map("suggestion_processing_status")
  suggestionProcessedAt        DateTime?                  @map("suggestion_processed_at") @db.Timestamptz(3)
  suggestionProcessingAttempts Int                        @default(0) @map("suggestion_processing_attempts")
  suggestionLastErrorCode      String?                    @map("suggestion_last_error_code") @db.VarChar(64)
  suggestionClaimUntil         DateTime?                  @map("suggestion_claim_until") @db.Timestamptz(3)
  suggestionClaimOwner         String?                    @map("suggestion_claim_owner") @db.VarChar(64)
  suggestionPolicyVersion      String?                    @map("suggestion_policy_version") @db.VarChar(64)
  createdAt                    DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  account     CommunicationAccount           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  excerpt     TemporaryCommunicationExcerpt?
  suggestions TaskSuggestion[]

  @@unique([organizationId, providerMessageId])
  @@unique([organizationId, dedupeKey])
  @@index([organizationId, internalDate])
  @@index([accountId, internalDate])
  @@index([organizationId, purgeAt])
  @@index([suggestionProcessingStatus, suggestionClaimUntil])
  @@index([organizationId, suggestionProcessingStatus])
  @@map("communication_events")
}

/// Temporary capped plain-text excerpt (D072). One active excerpt per event.
model TemporaryCommunicationExcerpt {
  id                   String    @id @db.VarChar(64)
  organizationId       String    @map("organization_id") @db.VarChar(64)
  communicationEventId String    @unique @map("communication_event_id") @db.VarChar(64)
  content              String    @db.VarChar(8192)
  byteLength           Int       @map("byte_length")
  purgeAt              DateTime  @map("purge_at") @db.Timestamptz(3)
  purgedAt             DateTime? @map("purged_at") @db.Timestamptz(3)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  event CommunicationEvent @relation(fields: [communicationEventId], references: [id], onDelete: Cascade)

  @@index([organizationId, purgeAt])
  @@map("temporary_communication_excerpts")
}

model GmailSyncRun {
  id               String           @id @db.VarChar(64)
  organizationId   String           @map("organization_id") @db.VarChar(64)
  accountId        String           @map("account_id") @db.VarChar(64)
  trigger          GmailSyncTrigger
  outcome          GmailSyncOutcome
  startedAt        DateTime         @map("started_at") @db.Timestamptz(3)
  finishedAt       DateTime?        @map("finished_at") @db.Timestamptz(3)
  historyIdBefore  String?          @map("history_id_before") @db.VarChar(128)
  historyIdAfter   String?          @map("history_id_after") @db.VarChar(128)
  messagesExamined Int              @default(0) @map("messages_examined")
  eventsCreated    Int              @default(0) @map("events_created")
  eventsUpdated    Int              @default(0) @map("events_updated")
  messagesSkipped  Int              @default(0) @map("messages_skipped")
  retryable        Boolean          @default(false)
  errorCode        String?          @map("error_code") @db.VarChar(64)
  requestId        String?          @map("request_id") @db.VarChar(64)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  account CommunicationAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([organizationId, startedAt])
  @@index([accountId, startedAt])
  @@map("gmail_sync_runs")
}

/// Short-lived, single-use Owner Gmail OAuth state + PKCE binding (A5.3, D069/D070).
/// Persists SHA-256 `stateHash` only (never the raw OAuth state) and an AES-256-GCM
/// encrypted PKCE verifier envelope. Rows are consumed atomically once and expire quickly;
/// they never contain OAuth tokens or authorization codes.
model GmailOAuthState {
  id                    String    @id @db.VarChar(64)
  /// SHA-256 hex digest of the raw OAuth `state`. Unique. Raw state is never stored.
  stateHash             String    @unique @map("state_hash") @db.VarChar(64)
  organizationId        String    @map("organization_id") @db.VarChar(64)
  ownerId               String    @map("owner_id") @db.VarChar(64)
  /// Purpose-bound AES-256-GCM envelope for the PKCE verifier. Nulled on consume.
  encryptedPkceVerifier String?   @map("encrypted_pkce_verifier") @db.Text
  encryptionKeyVersion  String    @map("encryption_key_version") @db.VarChar(64)
  redirectPath          String    @map("redirect_path") @db.VarChar(512)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt             DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt            DateTime? @map("consumed_at") @db.Timestamptz(3)

  @@index([organizationId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("gmail_oauth_states")
}

enum TaskStatus {
  open
  in_progress
  waiting
  completed
  dismissed
}

enum TaskSuggestionStatus {
  pending
  approved
  dismissed
  merged
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

/// A4 must not invent transitions into `used` (D056). Enum value reserved for future Decision only.
enum CapabilityStatus {
  active
  revoked
  expired
  used
}

enum AssignmentDeliveryStatus {
  pending
  sent
  failed
}

enum AuditActorKind {
  owner
  capability
  system
}

enum AuditOutcome {
  succeeded
  denied
  failed
}

enum CommunicationProvider {
  gmail
}

enum CommunicationAccountStatus {
  pending
  connected
  needs_reauth
  resync_required
  disconnected
  error
}

enum GmailHistoryState {
  unset
  valid
  resync_required
}

enum GmailSyncTrigger {
  cron
  manual
  initial
}

enum GmailSyncOutcome {
  running
  succeeded
  partial
  retryable_failure
  permanent_failure
  skipped_locked
  needs_reauth
  resync_required
}

enum CommunicationEventStatus {
  active
  purged
}

/// Durable suggestion-processing outcomes on CommunicationEvent (D081).
enum SuggestionProcessingStatus {
  unprocessed
  skipped_irrelevant
  suggestion_created
  failed_retryable
  failed_permanent
}
