{
  "name": "ai-communication-action-assistant",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @aicaa/web lint && pnpm --filter @aicaa/domain lint && pnpm --filter @aicaa/db lint && pnpm --filter @aicaa/ai lint",
    "test": "pnpm test:web && pnpm test:domain && pnpm test:contracts && pnpm test:db && pnpm test:ai",
    "test:web": "pnpm --filter @aicaa/web test",
    "test:domain": "pnpm --filter @aicaa/domain test",
    "test:contracts": "pnpm --filter @aicaa/contracts test",
    "test:db": "pnpm --filter @aicaa/db test",
    "test:ai": "pnpm --filter @aicaa/ai test",
    "build": "pnpm build:domain && pnpm build:ai && pnpm build:db && pnpm build:web",
    "build:web": "pnpm --filter @aicaa/web build",
    "build:domain": "pnpm --filter @aicaa/domain build",
    "build:ai": "pnpm --filter @aicaa/ai build",
    "build:db": "pnpm --filter @aicaa/db build",
    "db:generate": "pnpm --filter @aicaa/db generate",
    "db:validate": "pnpm --filter @aicaa/db validate",
    "contracts:validate": "pnpm --filter @aicaa/contracts validate",
    "contracts:bundle": "pnpm --filter @aicaa/contracts bundle",
    "contracts:generate": "pnpm --filter @aicaa/contracts generate",
    "contracts:generate:docker": "pnpm --filter @aicaa/contracts generate:docker",
    "contracts:check-drift": "pnpm --filter @aicaa/contracts check-drift",
    "android:ktlint": "cd apps/android && ./gradlew ktlintCheck",
    "android:test": "cd apps/android && ./gradlew testDebugUnitTest",
    "android:assemble": "cd apps/android && ./gradlew assembleDebug",
    "android:api-contract": "cd apps/android && ./gradlew :api-contract:compileDebugKotlin",
    "verify": "pnpm format:check && pnpm lint && pnpm contracts:validate && pnpm contracts:generate && pnpm contracts:check-drift && pnpm test && pnpm build:web && pnpm build:domain && pnpm android:ktlint && pnpm android:test && pnpm android:api-contract && pnpm android:assemble"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
