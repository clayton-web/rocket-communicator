# Supabase (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Application URL for OAuth redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Owner Google Workspace domain allowlist (authentication boundary only)
OWNER_WORKSPACE_DOMAIN=your-org.com

# Stable application organization identifier (not derived from email domain)
OWNER_ORGANIZATION_ID=org_your_organization_id

# Capability token runtime (server-only; never NEXT_PUBLIC)
# HMAC pepper for deterministic token lookup hashes (min 32 characters; do not commit real secrets)
CAPABILITY_TOKEN_PEPPER=replace-with-a-long-random-pepper-value
# TTL in milliseconds (D055 default seven days = 604800000)
CAPABILITY_TTL_MS=604800000

# Gmail OAuth (A5.3; server-only; never NEXT_PUBLIC). Names only — do not commit real values.
# Distinct from Supabase Owner authentication. Scope is gmail.readonly only.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/v1/gmail/oauth/callback when unset.
# GMAIL_OAUTH_REDIRECT_URL=
# AES-256-GCM key material: 32 raw bytes encoded as 64 hex chars OR standard/base64url base64.
GMAIL_TOKEN_ENCRYPTION_KEY=
# Explicit key version stored with each ciphertext envelope (e.g. "1").
GMAIL_TOKEN_ENCRYPTION_KEY_VERSION=

# Internal Gmail poll / Vercel Cron (A5.5; server-only; never NEXT_PUBLIC).
# Random secret, recommend ≥32 bytes. Vercel sends Authorization: Bearer <CRON_SECRET>.
# Configure in Production only; do not give Preview the production secret.
# Same CRON_SECRET authenticates POST /api/v1/internal/suggestions/process (A6.3).
# CRON_SECRET=

# Suggestion AI extraction (A6.3; server-only; never NEXT_PUBLIC). Names only — do not commit values.
# OPENAI_API_KEY=
# Optional OpenAI-compatible base URL (defaults to https://api.openai.com/v1).
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
# Set to "false" to disable extraction (process endpoint fails closed until configured).
# SUGGESTION_AI_ENABLED=
# SUGGESTION_AI_POLICY_VERSION=a6-suggestion-v1

# Server-side Postgres for Prisma (@aicaa/db). Prefer Supabase service-role / direct DB URL.
# Never expose this to the browser. Ordinary @aicaa/db Vitest suites use PGlite and do not need this.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
