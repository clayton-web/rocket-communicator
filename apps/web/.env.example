# Supabase (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Application URL for OAuth redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Owner Google Workspace domain allowlist (authentication boundary only)
OWNER_WORKSPACE_DOMAIN=your-org.com

# Stable application organization identifier (not derived from email domain)
OWNER_ORGANIZATION_ID=org_your_organization_id

# Capability token runtime (server-only; never NEXT_PUBLIC)
# HMAC pepper for deterministic token lookup hashes (min 32 characters; do not commit real secrets)
CAPABILITY_TOKEN_PEPPER=replace-with-a-long-random-pepper-value
# TTL in milliseconds (D055 default seven days = 604800000)
CAPABILITY_TTL_MS=604800000

# Server-side Postgres for Prisma (@aicaa/db). Prefer Supabase service-role / direct DB URL.
# Never expose this to the browser. Ordinary @aicaa/db Vitest suites use PGlite and do not need this.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
